# .env.example
DATABASE_URL=postgres://USER:PASS@HOST/db?sslmode=require
ANTHROPIC_API_KEY=sk-ant-...
VOYAGE_API_KEY=pa-...
# Linker active-edge confidence gate. Code fallback is 0.7; the eval-swept production value is 0.50
# (the link sweep is flat — P=R=F1=1.0 at every threshold 0.5–0.9 on the fixture).
LINK_THRESHOLD=0.50
